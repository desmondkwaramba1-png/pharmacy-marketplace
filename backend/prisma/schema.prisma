generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String?
  lastName     String?
  role         String   @default("pharmacist")
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pharmacy         Pharmacy?
  inventoryUpdates PharmacyInventory[]
  cart             Cart?
}

model Pharmacy {
  id             String  @id @default(cuid())
  name           String
  address        String
  suburb         String?
  city           String  @default("Harare")
  latitude       Float
  longitude      Float
  phone          String?
  email          String?
  operatingHours String? // JSON string
  logoUrl        String?
  isActive       Boolean @default(true)
  ownerId        String? @unique

  mcazLicenseNumber   String?
  mcazVerified        Boolean   @default(false)
  mcazVerifiedAt      DateTime?
  mcazSuspended       Boolean   @default(false)
  mcazSuspendReason   String?
  marketplaceStatus   String    @default("pending")
  licenseNumber       String?
  licenseExpiry       DateTime?
  licenseValid        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User?               @relation(fields: [ownerId], references: [id])
  inventory PharmacyInventory[]
  cartItems CartItem[]
  orders    Order[]
}

model Medicine {
  id            String  @id @default(cuid())
  genericName   String
  brandName     String?
  dosage        String?
  form          String?
  category      String?
  description   String?
  standardPrice Float?
  imageUrl      String?

  mcazRegNumber        String?
  distributionCategory String   @default("OTC")
  requiresPrescription Boolean  @default(false)
  advertisingClass     String   @default("freely_advertised")
  isMcazVerified       Boolean  @default(false)
  isBanned             Boolean  @default(false)
  otcAllowed           Boolean  @default(true)
  mcazRegistered       Boolean  @default(false)
  mcazSchedule         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory     PharmacyInventory[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  prescriptions Prescription[]
}

model PharmacyInventory {
  id               String   @id @default(cuid())
  pharmacyId       String
  medicineId       String
  stockStatus      String   @default("in_stock")
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0)
  price            Float?
  lastUpdated      DateTime @default(now())
  updatedById      String?

  pharmacy  Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine  Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  updatedBy User?    @relation(fields: [updatedById], references: [id])

  @@unique([pharmacyId, medicineId])
}

model Order {
  id              String   @id @default(cuid())
  bookingRef      String   @unique
  userId          String?
  pharmacyId      String
  totalAmount     Float    @default(0)
  deliveryFee     Float    @default(0)
  status          String   @default("pending") // pending | confirmed | out_for_delivery | delivered | collected | cancelled | expired
  paymentMethod   String   @default("in_person") // online | in_person
  paymentStatus   String   @default("pending") // pending | paid | failed
  deliveryMethod  String   @default("pickup") // pickup | delivery
  deliveryAddress String?
  deliveryNotes   String?
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  items           OrderItem[]
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  medicineId     String
  quantity       Int      @default(1)
  priceAtBooking Float    @default(0)
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicine       Medicine @relation(fields: [medicineId], references: [id])
}

model SearchLog {
  id           String   @id @default(cuid())
  searchQuery  String
  userLat      Float?
  userLng      Float?
  resultsCount Int      @default(0)
  searchedAt   DateTime @default(now())
}

model Prescription {
  id         String    @id @default(cuid())
  userId     String?
  medicineId String?
  fileUrl    String
  status     String    @default("pending") // pending | verified | rejected
  verifiedAt DateTime?
  expiresAt  DateTime?
  notes      String?
  createdAt  DateTime  @default(now())

  medicine  Medicine?  @relation(fields: [medicineId], references: [id])
  cartItems CartItem[]
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  pharmacyId     String
  medicineId     String
  quantity       Int      @default(1)
  reservedAt     DateTime @default(now())
  expiresAt      DateTime
  status         String   @default("reserved") // reserved | expired | checked_out
  prescriptionId String?

  cart         Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  medicine     Medicine      @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  pharmacy     Pharmacy      @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])

  @@unique([cartId, pharmacyId, medicineId])
}

// ── MCAZ COMPLIANCE CACHE TABLES ─────────────────────────────────────────────

model McazPremise {
  id                  Int      @id @default(autoincrement())
  licenseNumber       String   @unique
  premiseName         String
  physicalAddress     String
  city                String?
  pharmacistInCharge  String?
  licenseStatus       String   @default("Active") // Active | Suspended | Expired
  expiryDate          String?  // stored as string from scrape
  lastScrapedAt       DateTime @default(now())

  @@map("mcaz_premises")
}

model McazMedicine {
  id                   Int      @id @default(autoincrement())
  registrationNumber   String   @unique
  productName          String
  genericName          String
  strengthForm         String
  distributionCategory String   // PP | PIM | OTC
  applicantHolder      String?
  lastScrapedAt        DateTime @default(now())

  @@map("mcaz_medicines")
}

model McazPerson {
  id                 Int      @id @default(autoincrement())
  registrationNumber String   @unique
  fullName           String
  qualification      String?
  status             String   @default("Active")
  lastScrapedAt      DateTime @default(now())

  @@map("mcaz_persons")
}

model ScraperLog {
  id          Int      @id @default(autoincrement())
  target      String   // premises | medicines | persons
  status      String   // success | failed | partial
  rowsFound   Int      @default(0)
  errorMsg    String?
  ranAt       DateTime @default(now())

  @@map("scraper_logs")
}

// ── PRESCRIPTION RECORDS (5-year retention) ──────────────────────────────────

model PrescriptionRecord {
  id                    String   @id @default(cuid())
  orderId               String
  patientId             String?
  prescriptionImageUrl  String   // encrypted bucket URL
  pharmacistRegNo       String?  // verified against mcaz_persons
  pharmacistVerified    Boolean  @default(false)
  verifiedAt            DateTime?
  retainUntil           DateTime // 5 years from upload
  createdAt             DateTime @default(now())

  @@map("prescription_records")
}
