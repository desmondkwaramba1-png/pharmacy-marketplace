generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String?
  lastName     String?
  role         String   @default("pharmacist")
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pharmacy         Pharmacy?
  inventoryUpdates PharmacyInventory[]
  cart             Cart?
}

model Pharmacy {
  id             String  @id @default(cuid())
  name           String
  address        String
  suburb         String?
  city           String  @default("Harare")
  latitude       Float
  longitude      Float
  phone          String?
  email          String?
  operatingHours String? // JSON string
  logoUrl        String?
  isActive       Boolean @default(true)
  ownerId        String? @unique

  // MCAZ compliance fields
  mcazLicenseNumber String?
  mcazVerified      Boolean   @default(false)
  mcazVerifiedAt    DateTime?
  mcazSuspended     Boolean   @default(false)
  mcazSuspendReason String?
  marketplaceStatus String    @default("active") // active | suspended | pending

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User?               @relation(fields: [ownerId], references: [id])
  inventory PharmacyInventory[]
  cartItems CartItem[]
  orders    Order[]
}

model McazPremise {
  id                 String    @id @default(cuid())
  licenseNumber      String    @unique
  premiseName        String
  physicalAddress    String
  city               String?
  pharmacistInCharge String?
  licenseStatus      String    @default("Active")
  expiryDate         String?
  lastScrapedAt      DateTime  @default(now())
}

model McazMedicine {
  id                   String   @id @default(cuid())
  registrationNumber   String   @unique
  productName          String
  genericName          String?
  strengthForm         String?
  distributionCategory String   @default("OTC")
  applicantHolder      String?
  lastScrapedAt        DateTime @default(now())
}

model McazPerson {
  id                 String   @id @default(cuid())
  registrationNumber String   @unique
  fullName           String
  qualification      String?
  status             String   @default("Active")
  lastScrapedAt      DateTime @default(now())
}

model ScraperLog {
  id        String   @id @default(cuid())
  target    String   // premises | medicines | persons
  status    String   // success | failed
  rowsFound Int      @default(0)
  errorMsg  String?
  ranAt     DateTime @default(now())
}

model Medicine {
  id                   String  @id @default(cuid())
  genericName          String
  brandName            String?
  dosage               String?
  form                 String?
  category             String?
  description          String?
  standardPrice        Float?
  imageUrl             String?
  mcazRegNumber        String?
  distributionCategory String?
  requiresPrescription Boolean @default(false)
  advertisingClass     String?
  isMcazVerified       Boolean @default(false)
  isBanned             Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory  PharmacyInventory[]
  cartItems  CartItem[]
  orderItems OrderItem[]
}

model PharmacyInventory {
  id               String   @id @default(cuid())
  pharmacyId       String
  medicineId       String
  stockStatus      String   @default("in_stock")
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0)
  price            Float?
  lastUpdated      DateTime @default(now())
  updatedById      String?

  pharmacy  Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine  Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  updatedBy User?    @relation(fields: [updatedById], references: [id])

  @@unique([pharmacyId, medicineId])
}

model Order {
  id             String   @id @default(cuid())
  bookingRef     String   @unique
  userId         String?
  pharmacyId     String
  totalAmount    Float    @default(0)
  deliveryFee    Float    @default(0)
  status         String   @default("pending") // pending | confirmed | out_for_delivery | delivered | collected | cancelled | expired
  paymentMethod  String   @default("in_person") // online | in_person
  paymentStatus  String   @default("pending")  // pending | paid | failed
  deliveryMethod String   @default("pickup")   // pickup | delivery
  deliveryAddress String?
  deliveryNotes  String?
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  items          OrderItem[]
  pharmacy       Pharmacy  @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  medicineId     String
  quantity       Int     @default(1)
  priceAtBooking Float   @default(0)
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicine       Medicine @relation(fields: [medicineId], references: [id])
}

model SearchLog {
  id           String   @id @default(cuid())
  searchQuery  String
  userLat      Float?
  userLng      Float?
  resultsCount Int      @default(0)
  searchedAt   DateTime @default(now())
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  pharmacyId  String
  medicineId  String
  quantity    Int      @default(1)
  reservedAt  DateTime @default(now())
  expiresAt   DateTime
  status      String   @default("reserved") // reserved | expired | checked_out

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([cartId, pharmacyId, medicineId])
}
