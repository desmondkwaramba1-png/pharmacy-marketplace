{
  "expo": {
    "name": "AgriGuard AI",
    "slug": "agriguard-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B5E20"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.agriguard.ai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20"
      },
      "package": "com.agriguard.ai",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "AgriGuard needs camera access to scan crop leaves for disease detection."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AgriGuard needs photo access to analyze crop images from your gallery."
        }
      ]
    ]
  }
}
